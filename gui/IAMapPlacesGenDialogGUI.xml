<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg"/>

    <GuiElement profile="ia_mapplaces_gen_dialogBg" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" position="6px 0px"/>
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" position="6px 90px"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom" position="6px 0px"/>

        <BoxLayout profile="ia_mapplaces_gen_contentLayout" id="contentLayoutElement">
            <Text profile="ia_mapplaces_gen_title" text="$l10n_gui_mapplaces_gen_title" id="titleElement" />
            <Text profile="ia_mapplaces_gen_message" text="$l10n_gui_mapplaces_gen_message" id="messageElement" />
            <Text profile="ia_mapplaces_gen_message2" text="$l10n_gui_mapplaces_gen_message2" id="message2Element" />
            <Text profile="ia_mapplaces_gen_before_load" text="$l10n_gui_mapplaces_gen_before_load" id="beforeLoadElement" />
        </BoxLayout>

        <BoxLayout profile="fs25_dialogButtonBox" position="6px 32px">
            <Button profile="buttonOK" text="$l10n_gui_dialog_button_ok" onClick="onClickOk" id="okButton" />
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>
        <Profile name="ia_mapplaces_gen_dialogBg" extends="baseReference" with="pivotMiddleCenter">
            <size value="480px 480px"/>
        </Profile>

        <Profile name="ia_mapplaces_gen_contentLayout" extends="baseReference" with="pivotTopLeft">
            <size value="428px 380px"/>
            <position value="26px 26px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <elementSpacing value="12px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="true"/>
        </Profile>

        <Profile name="ia_mapplaces_gen_title" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 28px"/>
            <textSize value="22px"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapplaces_gen_message" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 120px"/>
            <textSize value="16px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="top"/>
            <textAutoHeight value="true"/>
            <textMaxWidth value="420px"/>
            <textMaxNumLines value="12"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapplaces_gen_message2" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 140px"/>
            <textSize value="15px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="top"/>
            <textAutoHeight value="true"/>
            <textMaxWidth value="420px"/>
            <textMaxNumLines value="14"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapplaces_gen_before_load" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 0px"/>
            <textSize value="16px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="top"/>
            <textAutoHeight value="true"/>
            <textMaxWidth value="420px"/>
            <textMaxNumLines value="6"/>
            <imageColor value="0 0 0 0"/>
        </Profile>
    </GUIProfiles>
</GUI>
