<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg"/>

    <GuiElement profile="ia_mapinit_dialogBg" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgTopSmall" position="6px 0px"/>
        <ThreePartBitmap profile="fs25_dialogBgMiddleSmall" position="6px 90px"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom" position="6px 0px"/>

        <BoxLayout profile="ia_mapinit_contentLayout" id="contentLayoutElement">
            <BoxLayout profile="ia_mapinit_tabBar" id="tabBarElement">
                <Button profile="ia_mapinit_tabButton" id="tabStoryButton" text="$l10n_gui_mapinit_tab_story" onClick="onClickTabStory" />
                <Button profile="ia_mapinit_tabButton" id="tabSettingsButton" text="$l10n_gui_mapinit_tab_settings" onClick="onClickTabSettings" />
            </BoxLayout>

            <BoxLayout profile="ia_mapinit_mainArea" id="storyContainer">
                <BoxLayout profile="ia_mapinit_storyColumnsRow" id="storyColumnsRow">
                    <!-- Left column (~34%): small help card pinned top-left + character list below -->
                    <BoxLayout profile="ia_mapinit_storyLeftColumn" id="storyLeftColumn">
                        <!-- Help card: small, white-bordered (thin colored bars, transparent interior), sticks to upper-left corner -->
                        <GuiElement profile="ia_mapinit_storyHelpBox" id="storyHelpBox">
                            <GuiElement profile="ia_mapinit_storyHelpBorderTop"/>
                            <GuiElement profile="ia_mapinit_storyHelpBorderBottom"/>
                            <GuiElement profile="ia_mapinit_storyHelpBorderLeft"/>
                            <GuiElement profile="ia_mapinit_storyHelpBorderRight"/>
                            <BoxLayout profile="ia_mapinit_storyHelpTextLayout" id="storyHelpTextLayout">
                                <Text profile="ia_mapinit_storyHelpTitle" text="$l10n_gui_mapinit_help_info_title" />
                                <Text profile="ia_mapinit_storyHelpBody" text="$l10n_gui_mapinit_help_info_body" />
                                <Text profile="ia_mapinit_storyHelpTitle" text="$l10n_gui_mapinit_characters_title" />
                            </BoxLayout>
                        </GuiElement>

                        <!-- Character list (scrollable). Populated at runtime from the template button. -->
                        <GuiElement profile="ia_mapinit_storyListScrollContainer" id="storyCharacterListScrollContainer">
                            <!-- framed background (existing) -->
                            <ThreePartBitmap profile="fs25_textInputBg" position="-15px 0px"/>

                            <!-- small invisible bitmaps used as top/bottom clippers for the scrolling viewport -->
                            <Bitmap id="storyListTopClipper" profile="emptyPanel" position="0px 0px" size="100% 6px" imageColor="0 0 0 0"/>
                            <Bitmap id="storyListBottomClipper" profile="emptyPanel" position="0px 0px" size="100% 6px" imageColor="0 0 0 0"/>

                            <!-- Scrolling layout — note the clipper attribute names pointing to the above elements -->
                            <ScrollingLayout profile="ia_mapinit_placeButtonsScrollingLayout"
                                            id="storyCharacterListScrollingLayout"
                                            topClipperElementName="storyListTopClipper"
                                            bottomClipperElementName="storyListBottomClipper">
                                <BoxLayout profile="ia_mapinit_placeButtonsBox" id="storyCharacterListBox">
                                    <Button profile="ia_mapinit_placeButton" id="storyCharacterButtonTemplate" name="storyCharacterButtonTemplate" onClick="onClickStoryCharacter" />
                                </BoxLayout>
                            </ScrollingLayout>

                            <!-- Vertical scrollbar track + engine Slider bound to the scrolling layout.
                                Adjust the `position` x offset so the track sits on the right edge of the framed background. -->
                            <ThreePartBitmap profile="ia_mapinit_listSliderTrack" size="8px 100%">
                                <Slider profile="fs25_listSlider"
                                        position="1px 0px"
                                        dataElementId="storyCharacterListScrollingLayout"
                                        size="8px 100%"/>
                            </ThreePartBitmap>
                        </GuiElement>
                    </BoxLayout>

                    <!-- Right area (~66%): selected character portrait + relationship -->
                    <BoxLayout profile="ia_mapinit_storyRightColumn" id="storyRightColumn">
                        <GuiElement profile="ia_mapinit_storyDataPanel" id="storyCharacterDataPanel">
                            <!-- No negative x-offset here: it would bleed the grey background into the gap between the two columns. -->
                            <ThreePartBitmap profile="fs25_textInputBg" position="0px 0px"/>
                            <BoxLayout profile="ia_mapinit_storyDataContent" id="storyCharacterDataContent">
                                <BoxLayout profile="ia_mapinit_storyPortraitRow" id="storyPortraitRow">
                                    <Bitmap profile="ia_mapinit_storyPortrait" id="storyCharacterPortrait" />
                                    <BoxLayout profile="ia_mapinit_storyInfoColumn" id="storyInfoColumn">
                                        <Text profile="ia_mapinit_storyDetailName" text="-" id="storyCharacterDataTitle" />
                                        <Text profile="ia_mapinit_storyDetailLabel" text="$l10n_gui_mapinit_story_relationship" id="storyRelationshipLabel" />
                                        <Text profile="ia_mapinit_storyDetailValue" text="-" id="storyRelationshipValue" />
                                        <Text profile="ia_mapinit_storyDetailLabel" text="$l10n_gui_mapinit_story_relationship_level" id="storyRelationshipLevelLabel" />
                                        <Text profile="ia_mapinit_storyDetailValueLarge" text="-" id="storyRelationshipLevelValue" />
                                    </BoxLayout>
                                </BoxLayout>
                                <Text profile="ia_mapinit_storyDetailLabel" text="$l10n_gui_mapinit_story_relationship_points" id="storyRelationshipPointsLabel" />
                                <GuiElement profile="ia_mapinit_storyProgressContainer" id="storyRelationshipProgressContainer">
                                    <Bitmap profile="ia_mapinit_storyProgressBg" id="storyRelationshipProgressBg" />
                                    <Bitmap profile="ia_mapinit_storyProgressFill" id="storyRelationshipProgressFill" />
                                    <Text profile="ia_mapinit_storyProgressText" text="0 / 0" id="storyRelationshipProgressText" />
                                </GuiElement>
                            </BoxLayout>
                        </GuiElement>
                    </BoxLayout>
                </BoxLayout>
            </BoxLayout>

            <BoxLayout profile="ia_mapinit_mainArea" id="settingsContainer">
            <BoxLayout profile="ia_mapinit_columnsRow" id="columnsRowElement">
                <!-- Column 1 (existing map init content; max width via inner wrapper) -->
                <BoxLayout profile="ia_mapinit_columnContainer" id="column1">
                    <BoxLayout profile="ia_mapinit_contentWrapper" id="contentWrapperElement">
                        <Text profile="ia_mapinit_title" text="$l10n_gui_mapinit_dialog_title" id="titleElement" />
                        <Text profile="ia_mapinit_message" text="$l10n_gui_mapinit_dialog_message" id="messageElement" />
                        <Button profile="ia_mapinit_sizeButton" id="placeSizeButton" text="$l10n_gui_mapinit_place_size_character" onClick="onClickPlaceSize" />
                        <Text profile="ia_mapinit_label" text="$l10n_gui_mapinit_place_type_label" />
                        <GuiElement profile="ia_mapinit_scrollContainer" id="placeButtonsScrollContainer">
                            <!-- Subtle framed background so it's obvious this list can scroll -->
                            <ThreePartBitmap profile="fs25_textInputBg" position="-15px 0px"/>
                            <Bitmap id="placeButtonsTopClipper" profile="emptyPanel" position="0px 0px" size="100% 6px" imageColor="0 0 0 0"/>
                            <Bitmap id="placeButtonsBottomClipper" profile="emptyPanel" position="0px 0px" size="100% 6px" imageColor="0 0 0 0"/>
                            <ScrollingLayout profile="ia_mapinit_placeButtonsScrollingLayout" id="placeButtonsScrollingLayout" topClipperElementName="placeButtonsTopClipper" bottomClipperElementName="placeButtonsBottomClipper">
                                <BoxLayout profile="ia_mapinit_placeButtonsBox" id="placeButtonsBox">
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_shop" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_gas_station" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_roadside" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_dirt_road" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_public_place" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_player_farm" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_public_relax_place" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_private_relax_place" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_sell_point" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_church" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_public_infrastructure" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_roadside_trees" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_industry" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_workshop" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" text="$l10n_gui_mapinit_place_type_shed" onClick="onClickPlaceType" />
                                    <Button profile="ia_mapinit_placeButton" id="characterHomeButtonTemplate" name="characterHomeButtonTemplate" onClick="onClickPlaceType" />
                                </BoxLayout>
                            </ScrollingLayout>
                            <ThreePartBitmap profile="ia_mapinit_listSliderTrack" size="8px 100%">
                                <Slider profile="fs25_listSlider" dataElementId="placeButtonsScrollingLayout" position="1px 0px" size="8px 100%"/>
                            </ThreePartBitmap>
                        </GuiElement>
                        <BoxLayout profile="ia_mapinit_actionsColumn" id="mapInitActionsColumn">
                            <BoxLayout profile="ia_mapinit_actionsLayout">
                                <Button profile="ia_mapinit_actionButton" text="$l10n_gui_mapinit_remove_nearest" onClick="onClickRemoveNearestPlace" />
                                <Button profile="ia_mapinit_actionButton" id="togglePlaceMarkersButton" text="$l10n_gui_mapinit_show_place_markers" onClick="onClickTogglePlaceDebugMarkers" />
                                <Button profile="ia_mapinit_actionButton" text="$l10n_gui_mapinit_nudge_vehicle_left" onClick="onClickNudgeVehicleLeft" />
                            </BoxLayout>
                            <Button profile="ia_mapinit_actionButtonFull" text="$l10n_gui_mapinit_end_init" onClick="onClickEndInitPhase" />
                        </BoxLayout>
                    </BoxLayout>
                </BoxLayout>

                <!-- Column 2 (placeholder content for later implementation) -->
                <BoxLayout profile="ia_mapinit_columnContainer" id="column2">
                    <BoxLayout profile="ia_mapinit_contentWrapper" id="charactersWrapperElement">
                        <Text profile="ia_mapinit_title" text="$l10n_gui_mapinit_characters_title" id="charactersTitleElement" />
                        <Text profile="ia_mapinit_message" text="$l10n_gui_mapinit_characters_message" id="charactersMessageElement" />

                        <!-- Character selector (simple switch: prev/next + current name label) -->
                        <BoxLayout profile="ia_mapinit_characterSelectorRow" id="characterSelectorRow">
                            <Button profile="ia_mapinit_characterSwitchButton" id="characterPrevButton" text="&lt;" onClick="onClickCharacterPrev" />
                            <Text profile="ia_mapinit_characterSelectedLabel" id="characterSelectedLabel" text="-" />
                            <Button profile="ia_mapinit_characterSwitchButton" id="characterNextButton" text="&gt;" onClick="onClickCharacterNext" />
                        </BoxLayout>

                        <!-- Character details (scrollable, same container/scroll structure as left box) -->
                        <GuiElement profile="ia_mapinit_scrollContainer" id="characterDetailsScrollContainer">
                            <ThreePartBitmap profile="fs25_textInputBg" position="-15px 0px"/>
                            <Bitmap id="characterDetailsTopClipper" profile="emptyPanel" position="0px 0px" size="100% 6px" imageColor="0 0 0 0"/>
                            <Bitmap id="characterDetailsBottomClipper" profile="emptyPanel" position="0px 0px" size="100% 6px" imageColor="0 0 0 0"/>
                            <ScrollingLayout profile="ia_mapinit_placeButtonsScrollingLayout" id="characterDetailsScrollingLayout" topClipperElementName="characterDetailsTopClipper" bottomClipperElementName="characterDetailsBottomClipper">
                                <BoxLayout profile="ia_mapinit_characterDetailsBox" id="characterDetailsBox">
                                    <Text profile="ia_mapinit_characterDetailText" id="characterDetailName" text="Name: -" />
                                    <Text profile="ia_mapinit_characterDetailText" id="characterDetailJob" text="Job: -" />
                                    <Text profile="ia_mapinit_characterDetailText" id="characterDetailRole" text="Role: -" />

                                    <Text profile="ia_mapinit_characterDetailHeader" id="characterDetailVehiclesHeader" text="Vehicles" />
                                    <Text profile="ia_mapinit_characterDetailText" id="characterDetailVehiclesList" text="-" />

                                    <Text profile="ia_mapinit_characterDetailHeader" id="characterDetailCurrentSituationHeader" text="Current situation" />
                                    <Text profile="ia_mapinit_characterDetailText" id="characterDetailCurrentSituation" text="-" />

                                    <Text profile="ia_mapinit_characterDetailHeader" id="characterDetailScheduleHeader" text="Planned fieldwork (today)" />
                                    <Text profile="ia_mapinit_characterDetailText" id="characterDetailSchedule" text="-" />
                                </BoxLayout>
                            </ScrollingLayout>
                            <ThreePartBitmap profile="ia_mapinit_listSliderTrack" size="8px 100%">
                                <Slider profile="fs25_listSlider" dataElementId="characterDetailsScrollingLayout" position="1px 0px" size="8px 100%"/>
                            </ThreePartBitmap>
                        </GuiElement>

                        <!-- Character actions -->
                        <BoxLayout profile="ia_mapinit_characterActionsLayout" id="characterActionsLayout">
                            <Button profile="ia_mapinit_characterActionButton" id="resetCharacterButton" text="RESET Character" onClick="onClickResetCharacter" />
                            <Button profile="ia_mapinit_characterActionButton" id="deleteCharacterButton" text="DELETE Character" onClick="onClickDeleteCharacter" />
                            <Button profile="ia_mapinit_characterActionButton" id="addNearestHomebaseButton" text="$l10n_gui_mapinit_add_nearest_homebase" onClick="onClickAddNearestHomebase" />
                            <Button profile="ia_mapinit_characterActionButton" id="removeHomeplacesButton" text="Remove Homeplaces" onClick="onClickRemoveHomeplaces" />
                        </BoxLayout>
                    </BoxLayout>
                </BoxLayout>

                <!-- Column 3 (placeholder content for later implementation) -->
                <BoxLayout profile="ia_mapinit_columnContainer" id="column3">
                    <BoxLayout profile="ia_mapinit_contentWrapper" id="placeholderWrapper3">
                        <Text profile="ia_mapinit_title" text="$l10n_gui_mapinit_general_actions_title" id="generalActionsTitleElement" />
                        <Text profile="ia_mapinit_message" text="$l10n_gui_mapinit_general_actions_message" id="generalActionsMessageElement" />

                        <BoxLayout profile="ia_mapinit_characterActionsLayout" id="generalActionsButtonsLayout">
                            <Button profile="ia_mapinit_characterActionButton" id="hideNearestGateButton" text="$l10n_gui_mapinit_hide_nearest_gate" onClick="onClickHideNearestGate" />
                            <Button profile="ia_mapinit_characterActionButton" id="removeModButton" text="$l10n_gui_mapinit_remove_mod" onClick="onClickRemoveMod" />
                            <Text profile="ia_mapinit_disclaimerText" id="removeModDisclaimerText" text="$l10n_gui_mapinit_remove_mod_disclaimer" />
                        </BoxLayout>
                    </BoxLayout>
                </BoxLayout>
            </BoxLayout>
        </BoxLayout>
        </BoxLayout>

        <BoxLayout profile="fs25_dialogButtonBox" position="6px 32px">
            <Button profile="buttonBack" text="$l10n_gui_dialog_button_cancel" onClick="onClickCancel" />
        </BoxLayout>
    </GuiElement>

    <GUIProfiles>
        <Profile name="ia_mapinit_dialogBg" extends="baseReference" with="pivotMiddleCenter">
            <size value="95% 80%"/>
        </Profile>

        <Profile name="ia_mapinit_listSliderTrack" extends="fs25_listSliderBox" with="anchorTopRight pivotTopRight">
            <position value="15px 0px"/>
        </Profile>

        <Profile name="ia_mapinit_contentLayout" extends="baseReference" with="pivotTopLeft">
            <size value="100% 100%"/>
            <position value="26px 26px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fitFlowToElements value="false"/>
            <elementSpacing value="10px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
        </Profile>

        <Profile name="ia_mapinit_tabBar" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 44px"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="horizontal"/>
            <fillDirectionX value="leftToRight"/>
            <elementSpacing value="8px"/>
            <alignmentX value="left"/>
            <alignmentY value="middle"/>
        </Profile>

        <Profile name="ia_mapinit_tabButton" extends="baseReference">
            <size value="180px 40px"/>
            <textAlignment value="center"/>
            <textSize value="16px"/>
            <imageColor value="$preset_fs25_colorMainDark_90"/>
            <imageHighlightedColor value="$preset_fs25_colorMainDark"/>
            <imageFocusedColor value="$preset_fs25_colorMainDark"/>
            <handleFocus value="true"/>
        </Profile>

        <Profile name="ia_mapinit_mainArea" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 100%"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fitFlowToElements value="false"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
        </Profile>

        <Profile name="ia_mapinit_columnsRow" extends="baseReference" with="anchorTopLeft">
            <size value="100% 100%"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="horizontal"/>
            <fillDirectionX value="leftToRight"/>
            <elementSpacing value="0px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="false"/>
        </Profile>

        <Profile name="ia_mapinit_columnContainer" extends="baseReference" with="anchorTopLeft">
            <size value="33% 100%"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fillDirectionY value="topToBottom"/>
            <elementSpacing value="0px"/>
            <alignmentX value="center"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="false"/>
        </Profile>

        <!-- Wrapper fills content layout (inset is on content layout position/size). -->
        <Profile name="ia_mapinit_contentWrapper" extends="baseReference" with="anchorTopCenter pivotTopCenter">
            <size value="380px 100%"/>
            <position value="0px 0px"/>
            <margin value="0px 0px 0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fillDirectionY value="topToBottom"/>
            <elementSpacing value="8px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="false"/>
        </Profile>

        <Profile name="ia_mapinit_characterSelectorRow" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 36px"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="horizontal"/>
            <fillDirectionX value="leftToRight"/>
            <elementSpacing value="8px"/>
            <alignmentX value="center"/>
            <alignmentY value="middle"/>
        </Profile>

        <Profile name="ia_mapinit_characterSwitchButton" extends="baseReference">
            <size value="44px 36px"/>
            <textAlignment value="center"/>
            <textSize value="18px"/>
            <imageColor value="$preset_fs25_colorMainDark_90"/>
            <imageHighlightedColor value="$preset_fs25_colorMainDark"/>
            <imageFocusedColor value="$preset_fs25_colorMainDark"/>
        </Profile>

        <Profile name="ia_mapinit_characterSelectedLabel" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 36px"/>
            <textSize value="16px"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapinit_characterDetailHeader" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 22px"/>
            <textSize value="16px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapinit_characterDetailText" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 0px"/>
            <textSize value="14px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="top"/>
            <textAutoHeight value="true"/>
            <textMaxWidth value="350px"/>
            <!-- Omitting textMaxNumLines defaults to single-line + ellipsis; allow long wrapped / newline-separated lists. -->
            <textMaxNumLines value="1000"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapinit_title" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 28px"/>
            <position value="0px 0px"/>
            <textSize value="22px"/>
            <textAlignment value="center"/>
            <textVerticalAlignment value="middle"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapinit_message" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 48px"/>
            <position value="0px 0px"/>
            <textSize value="16px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="top"/>
            <textAutoHeight value="true"/>
            <textMaxWidth value="350px"/>
            <textMaxNumLines value="5"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <Profile name="ia_mapinit_label" extends="baseReference" with="anchorTopStretchingX">
            <size value="100% 22px"/>
            <position value="0px 0px"/>
            <textSize value="16px"/>
            <textAlignment value="left"/>
            <textVerticalAlignment value="middle"/>
            <imageColor value="0 0 0 0"/>
        </Profile>

        <!-- ===== Story tab layout: left column (help card + character list) | right data area ===== -->
        <!-- Spacing comes from the column margins (outer edges + shared gap), like columnContainer/contentWrapper; no elementSpacing here. -->
        <Profile name="ia_mapinit_storyColumnsRow" extends="baseReference" with="anchorStretchingYStretchingX pivotTopLeft">
            <size value="100% 100%"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="horizontal"/>
            <fillDirectionX value="leftToRight"/>
            <elementSpacing value="0px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="false"/>
        </Profile>

        <!-- margin = left top right bottom. 24px outer-left + 12px half of the gap; widths + margins stay < 100%. -->
        <Profile name="ia_mapinit_storyLeftColumn" extends="baseReference" with="anchorStretchingYStretchingX pivotTopLeft">
            <size value="33% 85%"/>
            <position value="0px 0px"/>
            <margin value="12px 0px 24px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fillDirectionY value="topToBottom"/>
            <elementSpacing value="0px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="false"/>
        </Profile>

        <!-- 12px half of the gap + 24px outer-right edge. -->
        <Profile name="ia_mapinit_storyRightColumn" extends="baseReference" with="anchorStretchingYStretchingX pivotTopLeft">
            <size value="60% 85%"/>
            <position value="0px 0px"/>
            <margin value="12px 0px 24px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fillDirectionY value="topToBottom"/>
            <elementSpacing value="8px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="false"/>
        </Profile>

        <!-- Small help card pinned to the upper-left of the story area. Transparent interior; white outline drawn by 4 border bars. Fixed pixel height so the stretchy scroll container below fills exactly the remaining column height. -->
        <Profile name="ia_mapinit_storyHelpBox" extends="emptyPanel" with="anchorTopStretchingX pivotTopLeft">
            <size value="100% 20%"/>
            <position value="0px 0px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
        </Profile>

        <!-- White border bars: each renders a solid quad via its color (no texture needed). -->
        <Profile name="ia_mapinit_storyHelpBorder" extends="baseReference">
            <imageColor value="0 0 0 0"/>
            <color value="1 1 1 1"/>
        </Profile>
        <Profile name="ia_mapinit_storyHelpBorderTop" extends="ia_mapinit_storyHelpBorder" with="anchorTopLeft pivotTopLeft">
            <size value="100% 2px"/>
            <position value="0px 0px"/>
        </Profile>
        <Profile name="ia_mapinit_storyHelpBorderBottom" extends="ia_mapinit_storyHelpBorder" with="anchorBottomLeft pivotBottomLeft">
            <size value="100% 2px"/>
            <position value="0px 0px"/>
        </Profile>
        <Profile name="ia_mapinit_storyHelpBorderLeft" extends="ia_mapinit_storyHelpBorder" with="anchorTopLeft pivotTopLeft">
            <size value="2px 100%"/>
            <position value="0px 0px"/>
        </Profile>
        <Profile name="ia_mapinit_storyHelpBorderRight" extends="ia_mapinit_storyHelpBorder" with="anchorTopRight pivotTopRight">
            <size value="2px 100%"/>
            <position value="0px 0px"/>
        </Profile>

        <!-- Stretch + margin = padding so the text doesn't touch the white border. -->
        <Profile name="ia_mapinit_storyHelpTextLayout" extends="baseReference" with="anchorStretchingYStretchingX pivotTopLeft">
            <size value="100% 100%"/>
            <position value="0px 0px"/>
            <margin value="16px 14px 16px 14px"/>
            <imageColor value="0 0 0 0"/>
            <color value="0 0 0 0"/>
            <flowDirection value="vertical"/>
            <fillDirectionY value="topToBottom"/>
            <elementSpacing value="6px"/>
            <alignmentX value="left"/>
            <alignmentY value="top"/>
            <fitFlowToElements value="true"/>
        </Profile>

        <Profile name="ia_mapinit_storyHelpTitle" extends="baseReference" with="anchorTopStretchingX">
