<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
  Per-character voice + text catalog for dynamic conversations
  (conversations/dynamic/<characterId>/<topic>/<variant>/).

  OGG filenames: {lang}_{gender}_{voiceId}_{suffix}.ogg — voiceId comes from the neighbour (character-specific).

  Each entry maps a placeholder VALUE (`#key`) to:
    * `#suffix` — voice clip filename stem (used for both subtitle audio and helper-generated TTS),
    * `#text`   — English subtitle text substituted in for the placeholder,
    * `#textDe` — German subtitle text substituted in for the placeholder.

  Variable catalogs (element name == placeholder variable, case-insensitive):
    <jobType>                 — keyed by IAFieldwork.JobType.* (cultivate, harrow, harvest, manure_spreading, slurry_spreading, fertilizer_spreading, spray, seed, plow, ia_field_outcome, other)
    <vehicleNameWithArticle>  — keyed by the same enum value as jobType
    <extraRefillNote>         — keyed by "needed" (set only when the implement consumes refillable material)
    <FieldNumber>             — numeric keys (clamped) shared by {fieldNumber}, {fieldNumbers}, {totalHectares}

  Optional <character id="…"> sections override or extend the defaults for that neighbour id.
-->
<voiceCatalog>
